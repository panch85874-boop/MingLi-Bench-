# Copy to .env and fill in only what you plan to use.
# Empty / placeholder values are skipped automatically.

# ============================================
# Speech-to-text (STT)
# ============================================
# Engine: "local" (faster-whisper, runs on this machine, no API key needed)
#      or "api"   (OpenAI-compatible Whisper endpoint)
STT_ENGINE=local

# Local engine tuning (only used when STT_ENGINE=local)
WHISPER_MODEL_SIZE=small
# WHISPER_DEVICE=cpu          # cpu | cuda
# WHISPER_COMPUTE_TYPE=int8   # int8 | float16 | float32

# API engine (only used when STT_ENGINE=api)
OPENAI_API_KEY=your_openai_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================
# Speaker diarization (optional)
# ============================================
# Requires `pip install -r requirements-diarize.txt` and a Hugging Face token
# that has accepted the pyannote/speaker-diarization-3.1 model terms.
HUGGINGFACE_TOKEN=

# ============================================
# LLM summarization — one key, most models, via OpenRouter
# ============================================
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Native providers (only if you call them directly instead of OpenRouter)
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Local LLM via Ollama (OpenAI-compatible endpoint, no key required)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Default summarization model (provider/model form routes via OpenRouter,
# a bare name routes to the matching native/local provider above)
SUMMARY_MODEL=anthropic/claude-sonnet-5

# ============================================
# Storage
# ============================================
# SQLite database file (created automatically on first run)
MEETING_SCRIBE_DB=./data/meetings.db
